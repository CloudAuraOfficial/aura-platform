{
  "baseEssence": {
    "EssenceName": "AwsS3Bucket",
    "EssenceID": "a1b2c3d4-2222-3333-4444-555566667777",
    "cloudProvider": "Aws",
    "subscriptionId": "000000000000",
    "uniqueId": "aura-aws-bucket",
    "baseLoad": "EmissionLoadS3",
    "defaultRegion": "us-east-1"
  },
  "layers": {
    "CreateBucket": {
      "isEnabled": true,
      "operationType": "CreateS3Bucket",
      "parameters": {
        "bucketName": "aura-demo-${BYOS_AWS_ACCOUNT_ID}-bucket",
        "versioning": true,
        "publicAccessBlock": true
      }
    },
    "DeleteBucket": {
      "isEnabled": true,
      "operationType": "DeleteS3Bucket",
      "parameters": {
        "bucketName": "aura-demo-${BYOS_AWS_ACCOUNT_ID}-bucket",
        "force": true
      },
      "dependsOn": ["CreateBucket"]
    }
  }
}
