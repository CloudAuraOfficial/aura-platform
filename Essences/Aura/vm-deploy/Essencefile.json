{
  "baseEssence": {
    "EssenceName": "DeploySmallVM",
    "EssenceID": "b2c3d4e5-f6a7-8901-bcde-f23456789012",
    "cloudProvider": "Azure",
    "subscriptionId": "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx",
    "tenantId": "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx",
    "uniqueId": "cloudaura-vm",
    "baseLoad": "EmissionLoadVM",
    "defaultRegion": "eastus",
    "Schedule": "*/5 * * * *"
  },
  "layers": {
    "ResourceGroup": {
      "isEnabled": true,
      "operationType": "CreateResourceGroup",
      "parameters": {
        "resourceGroupName": "cloudaura-vm-rg",
        "location": "westus2"
      }
    },
    "CreateVM": {
      "isEnabled": true,
      "operationType": "CreateVM",
      "parameters": {
        "vmName": "cloudaura-vm",
        "resourceGroup": "cloudaura-vm-rg",
        "location": "westus2",
        "vmSize": "Standard_D2s_v3",
        "adminUsername": "azureuser",
        "adminPassword": "${BYOS_VM_ADMIN_PASSWORD}",
        "osImage": {
          "publisher": "Canonical",
          "offer": "ubuntu-24_04-lts",
          "sku": "server",
          "version": "latest"
        },
        "osDiskSizeGB": 30,
        "openPorts": [22, 80, 443]
      },
      "dependsOn": ["ResourceGroup"]
    },
    "StopVM": {
      "isEnabled": true,
      "operationType": "StopVM",
      "parameters": {
        "vmName": "cloudaura-vm",
        "resourceGroup": "cloudaura-vm-rg"
      },
      "dependsOn": ["CreateVM"]
    },
    "DeleteVM": {
      "isEnabled": true,
      "operationType": "DeleteVM",
      "parameters": {
        "vmName": "cloudaura-vm",
        "resourceGroup": "cloudaura-vm-rg",
        "deleteNetworking": true
      },
      "dependsOn": ["StopVM"]
    },
    "DeleteResourceGroup": {
      "isEnabled": true,
      "operationType": "DeleteResourceGroup",
      "parameters": {
        "resourceGroupName": "cloudaura-vm-rg"
      },
      "dependsOn": ["DeleteVM"]
    }
  }
}
