{
  "baseEssence": {
    "cloudProvider": "Azure",
    "defaultRegion": "eastus",
    "baseLoad": "EmissionLoadVM",
    "uniqueId": "aura-multi-vm-loop",
    "subscriptionId": ""
  },
  "layers": {
    "create-rg": {
      "isEnabled": true,
      "operationType": "CreateResourceGroup",
      "parameters": {
        "resourceGroup": "aura-multi-vm-rg",
        "location": "eastus"
      },
      "_approach": "Create the resource group for all VMs"
    },
    "deploy-vms": {
      "isEnabled": true,
      "operationType": "DeployArmTemplate",
      "dependsOn": ["create-rg"],
      "parameters": {
        "resourceGroup": "aura-multi-vm-rg",
        "templatePath": "/app/templates/multi-vm-arm-template.json",
        "deploymentName": "aura-multi-vm-deploy",
        "templateParameters": {
          "vmNamePrefix": "AuraVM",
          "parallelCount": 2,
          "sequentialCount": 2,
          "location": "eastus",
          "vmSize": "Standard_B1s",
          "adminUsername": "azureuser",
          "adminPassword": "${BYOS_VM_ADMIN_PASSWORD}",
          "osDiskSizeGB": 30
        }
      },
      "_approach": "Deploy 4 VMs via ARM copy loop: 2 parallel x 2 sequential. Batch 1: AuraVM_0_0 + AuraVM_1_0. Batch 2: AuraVM_0_1 + AuraVM_1_1."
    },
    "delete-vm-0-0": {
      "isEnabled": true,
      "operationType": "DeleteVM",
      "dependsOn": ["deploy-vms"],
      "parameters": {
        "resourceGroup": "aura-multi-vm-rg",
        "vmName": "AuraVM_0_0"
      },
      "_approach": "Delete VM AuraVM_0_0"
    },
    "delete-vm-0-1": {
      "isEnabled": true,
      "operationType": "DeleteVM",
      "dependsOn": ["deploy-vms"],
      "parameters": {
        "resourceGroup": "aura-multi-vm-rg",
        "vmName": "AuraVM_0_1"
      },
      "_approach": "Delete VM AuraVM_0_1"
    },
    "delete-vm-1-0": {
      "isEnabled": true,
      "operationType": "DeleteVM",
      "dependsOn": ["deploy-vms"],
      "parameters": {
        "resourceGroup": "aura-multi-vm-rg",
        "vmName": "AuraVM_1_0"
      },
      "_approach": "Delete VM AuraVM_1_0"
    },
    "delete-vm-1-1": {
      "isEnabled": true,
      "operationType": "DeleteVM",
      "dependsOn": ["deploy-vms"],
      "parameters": {
        "resourceGroup": "aura-multi-vm-rg",
        "vmName": "AuraVM_1_1"
      },
      "_approach": "Delete VM AuraVM_1_1"
    },
    "delete-rg": {
      "isEnabled": true,
      "operationType": "DeleteResourceGroup",
      "dependsOn": ["delete-vm-0-0", "delete-vm-0-1", "delete-vm-1-0", "delete-vm-1-1"],
      "parameters": {
        "resourceGroup": "aura-multi-vm-rg"
      },
      "_approach": "Delete the resource group after all VMs are removed"
    }
  }
}
