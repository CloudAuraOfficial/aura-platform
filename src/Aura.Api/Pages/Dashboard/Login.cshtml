@page "/dashboard/login"
@{
    ViewData["Title"] = "Login";
    Layout = "/Pages/Shared/_Layout.cshtml";
}

<div class="login-container">
    <div class="card">
        <h1>Sign In</h1>
        <div id="error" class="alert alert-error" style="display:none"></div>
        <form id="loginForm">
            <div class="form-group">
                <label>Email</label>
                <input type="email" id="email" required autofocus />
            </div>
            <div class="form-group">
                <label>Password</label>
                <input type="password" id="password" required />
            </div>
            <button type="submit" class="btn btn-primary" style="width:100%">Sign In</button>
        </form>
    </div>
</div>

<script>
document.getElementById('loginForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    const err = document.getElementById('error');
    err.style.display = 'none';
    try {
        const res = await fetch('/api/v1/auth/login', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                email: document.getElementById('email').value,
                password: document.getElementById('password').value
            })
        });
        const data = await res.json();
        if (!res.ok) { err.textContent = data.message || 'Login failed'; err.style.display = 'block'; return; }
        localStorage.setItem('aura_token', data.token);
        localStorage.setItem('aura_refresh', data.refreshToken);
        window.location.href = '/dashboard';
    } catch (ex) {
        err.textContent = 'Connection error'; err.style.display = 'block';
    }
});
</script>
