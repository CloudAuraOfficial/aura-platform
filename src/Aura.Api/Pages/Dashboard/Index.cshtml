@page "/dashboard"
@{
    ViewData["Title"] = "Dashboard";
    Layout = "/Pages/Shared/_Layout.cshtml";
}

<h1>Dashboard</h1>

<div class="stat-grid">
    <div class="stat"><div class="stat-value" id="essenceCount">-</div><div class="stat-label">Essences</div></div>
    <div class="stat"><div class="stat-value" id="deploymentCount">-</div><div class="stat-label">Deployments</div></div>
    <div class="stat"><div class="stat-value" id="userCount">-</div><div class="stat-label">Users</div></div>
    <div class="stat"><div class="stat-value" id="accountCount">-</div><div class="stat-label">Cloud Accounts</div></div>
</div>

<h2>Recent Deployment Runs</h2>
<div id="recentRuns"><div class="empty">Loading...</div></div>

<script>
const token = localStorage.getItem('aura_token');
if (!token) window.location.href = '/dashboard/login';

async function api(path) {
    const res = await fetch(path, { headers: { 'Authorization': 'Bearer ' + token } });
    if (res.status === 401) { window.location.href = '/dashboard/login'; return null; }
    return await res.json();
}

function badge(status) {
    const map = { Succeeded: 'success', Failed: 'danger', Running: 'warning', Queued: 'info', Cancelled: 'muted', Pending: 'muted' };
    return `<span class="badge badge-${map[status] || 'muted'}">${status}</span>`;
}

(async () => {
    const [essences, deployments, users, accounts] = await Promise.all([
        api('/api/v1/essences?limit=1'), api('/api/v1/deployments?limit=1'),
        api('/api/v1/users?limit=1'), api('/api/v1/cloud-accounts?limit=1')
    ]);
    if (essences) document.getElementById('essenceCount').textContent = essences.total;
    if (deployments) document.getElementById('deploymentCount').textContent = deployments.total;
    if (users) document.getElementById('userCount').textContent = users.total;
    if (accounts) document.getElementById('accountCount').textContent = accounts.total;

    // Fetch recent runs from all deployments
    if (deployments && deployments.items?.length > 0) {
        const allRuns = [];
        for (const d of (await api('/api/v1/deployments?limit=100'))?.items || []) {
            const runs = await api(`/api/v1/deployments/${d.id}/runs?limit=5`);
            if (runs?.items) runs.items.forEach(r => allRuns.push({ ...r, deploymentName: d.name }));
        }
        allRuns.sort((a, b) => new Date(b.createdAt) - new Date(a.createdAt));
        const recent = allRuns.slice(0, 10);
        if (recent.length === 0) {
            document.getElementById('recentRuns').innerHTML = '<div class="empty">No runs yet</div>';
        } else {
            document.getElementById('recentRuns').innerHTML = `<table><thead><tr>
                <th>Deployment</th><th>Status</th><th>Layers</th><th>Started</th><th>Duration</th>
            </tr></thead><tbody>${recent.map(r => {
                const started = r.startedAt ? new Date(r.startedAt).toLocaleString() : '-';
                const dur = r.startedAt && r.completedAt ? Math.round((new Date(r.completedAt) - new Date(r.startedAt))/1000) + 's' : '-';
                return `<tr><td>${r.deploymentName || '-'}</td><td>${badge(r.status)}</td>
                    <td>${r.layers?.length || 0}</td><td>${started}</td><td>${dur}</td></tr>`;
            }).join('')}</tbody></table>`;
        }
    } else {
        document.getElementById('recentRuns').innerHTML = '<div class="empty">No deployments yet</div>';
    }
})();
</script>
