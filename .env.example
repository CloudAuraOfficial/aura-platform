# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=aura
POSTGRES_USER=aura
POSTGRES_PASSWORD=changeme

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=change-me-to-a-64-char-random-string
JWT_ISSUER=aura-platform
JWT_AUDIENCE=aura-platform
JWT_EXPIRY_MINUTES=60

# Encryption (base64-encoded 32-byte key for AES-256)
ENCRYPTION_KEY=change-me-to-a-32-byte-base64-key

# Worker
WORKER_CONCURRENCY=5
RUN_STALE_THRESHOLD_SECONDS=7200
SCHEDULER_POLL_SECONDS=30

# CORS (comma-separated origins, empty = allow any)
CORS_ORIGINS=https://platform.cloudaura.cloud

# Deploy webhook (optional — enables POST /api/internal/deploy)
DEPLOY_WEBHOOK_SECRET=

# EmissionLoad (container-based execution)
EXECUTION_MODE=InProcess
EMISSIONLOAD_MEMORY_LIMIT=512m
EMISSIONLOAD_CPU_LIMIT_NANOCPUS=1000000000
EMISSIONLOAD_TIMEOUT_SECONDS=600

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://172.17.0.1:4317

# Application
ASPNETCORE_ENVIRONMENT=Production
