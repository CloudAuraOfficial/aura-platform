# Azure Deployment Configuration
# Copy to .env.azure and fill in values. NEVER commit .env.azure.

# --- Azure Resources ---
AZURE_RESOURCE_GROUP=cloudaura-rg
AZURE_ACR_NAME=cloudauraregistry
AZURE_LOCATION=eastus
AZURE_DNS_LABEL=cloudaura-api

# --- Service Principal (for CI/CD) ---
AZURE_SUBSCRIPTION_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# --- Application Secrets ---
JWT_SECRET=                    # Min 64 chars
ENCRYPTION_KEY=                # Base64-encoded 32-byte key (openssl rand -base64 32)
POSTGRES_PASSWORD=             # PostgreSQL password

# --- Optional Overrides ---
# IMAGE_TAG=latest             # Docker image tag (default: latest)
# JWT_ISSUER=aura-api
# JWT_AUDIENCE=aura-client
# JWT_EXPIRY_MINUTES=60
# CORS_ORIGINS=*
